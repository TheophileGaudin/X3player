<?xml version="1.0" encoding="utf-8"?>
<com.x3player.glasses.binocular.BinocularPlayerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/binocularLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_black">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/permissionPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/panel_background"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/permission_title"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/permission_message"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/permissionButton"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/grant_access" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/permissionSecondaryButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/check_again" />
        </LinearLayout>
    </FrameLayout>

</com.x3player.glasses.binocular.BinocularPlayerLayout>
